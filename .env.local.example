# ── Local Development Overrides ──
# Copy this to .env.local and fill in your values.
# .env.local is gitignored and takes precedence over .env

# ── Custom Domain (required for production) ──
DOMAIN_NAME=portal.example.com

# ── Cloudflare (required for SST DNS provider) ──
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_DEFAULT_ACCOUNT_ID=your_cloudflare_account_id

# ── Auth (NextAuth) ──
AUTH_SECRET=generate_with_npx_auth_secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Analytics (optional) ──
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ── API Keys (add your own) ──
# OPENAI_API_KEY=
# DATABASE_URL=
