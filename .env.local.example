# ── Local Development Overrides ──
# Copy this to .env.local and fill in your values.
# .env.local is gitignored and takes precedence over .env

# ── Boilerplate placeholders: replace before first real deploy ──
NEXT_PUBLIC_SITE_URL=https://boilerplate.example.com
NEXT_PUBLIC_ENABLE_PWA=true
DOMAIN_NAME=replace-me.example.com

# ── Cloudflare (required for SST DNS provider) ──
CLOUDFLARE_API_TOKEN=replace-me
CLOUDFLARE_DEFAULT_ACCOUNT_ID=replace-me

# ── Auth (NextAuth) ──
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Analytics (optional) ──
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ── API Keys (add your own) ──
# OPENAI_API_KEY=
# DATABASE_URL=
