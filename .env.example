# ── AWS ──
AWS_REGION=eu-west-3
AWS_ROLE_ARN=arn:aws:iam::role/tech-portal-deploy

# ── Terraform ──
TF_VAR_project_name=tech-portal
TF_VAR_environment=production
TF_VAR_domain_name=
TF_VAR_acm_certificate_arn=

# ── App ──
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_GA_ID=

# ── Cloudflare DNS ──
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_RECORD_NAME=portal.example.com
