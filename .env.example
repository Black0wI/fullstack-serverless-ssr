# ── AWS ──
AWS_REGION=eu-west-3
AWS_PROFILE=default

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# ── SST ──
# SST_STAGE=production

# ── Custom Domain (optional) ──
# DOMAIN_NAME=portal.example.com

# ── Cloudflare DNS (optional) ──
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
