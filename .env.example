# ── AWS ──
AWS_REGION=eu-west-3
AWS_PROFILE=default

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:4040
NEXT_PUBLIC_ENABLE_PWA=true

# ── SST ──
# SST_STAGE=production

# ── Auth.js (uncomment to enable) ──
# AUTH_SECRET=              # Generate with: npx auth secret
# AUTH_GOOGLE_ID=           # Google OAuth Client ID
# AUTH_GOOGLE_SECRET=       # Google OAuth Client Secret

# ── Production Deploy (required before first real deploy) ──
DOMAIN_NAME=replace-me.example.com

# ── Cloudflare DNS (required for SST + Cloudflare DNS) ──
CLOUDFLARE_API_TOKEN=replace-me
CLOUDFLARE_DEFAULT_ACCOUNT_ID=replace-me

# ── Cloudflare Web Analytics (optional) ──
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
